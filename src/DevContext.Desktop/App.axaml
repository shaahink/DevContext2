<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DevContext.Desktop.Converters"
             x:Class="DevContext.Desktop.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <!-- Converter -->
        <converters:ScenarioIconConverter x:Key="ScenarioIconConverter"/>

        <!-- Catppuccin Latte palette -->
        <Color x:Key="Crust">#dce0e8</Color>
        <Color x:Key="Mantle">#e6e9ef</Color>
        <Color x:Key="Base">#eff1f5</Color>
        <Color x:Key="Surface0">#ccd0da</Color>
        <Color x:Key="Surface1">#bcc0cc</Color>
        <Color x:Key="Surface2">#acb0be</Color>
        <Color x:Key="Overlay0">#9ca0b0</Color>
        <Color x:Key="Text">#4c4f69</Color>
        <Color x:Key="Blue">#1e66f5</Color>
        <Color x:Key="Green">#40a02b</Color>
        <Color x:Key="Red">#d20f39</Color>
        <Color x:Key="Yellow">#df8e1d</Color>

        <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource Crust}"/>
        <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource Mantle}"/>
        <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource Base}"/>
        <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0}"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
        <SolidColorBrush x:Key="Overlay0Brush" Color="{StaticResource Overlay0}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text}"/>
        <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource Blue}"/>
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>

        <!-- Override Fluent accent to match Catppuccin blue -->
        <Color x:Key="SystemAccentColor">#1e66f5</Color>
        <Color x:Key="SystemAccentColorLight1">#4c8dff</Color>
        <Color x:Key="SystemAccentColorLight2">#8ab4ff</Color>
        <Color x:Key="SystemAccentColorDark1">#1545b3</Color>
        <Color x:Key="SystemAccentColorDark2">#0e2f7a</Color>

        <!-- ══ Material Design Icon geometries ═════════════════════════════════════ -->
        <StreamGeometry x:Key="IconFolderOpen">M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z</StreamGeometry>
        <StreamGeometry x:Key="IconFileDocument">M6,2A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6M6,4H13V9H18V20H6V4M8,12V14H16V12H8M8,16V18H13V16H8Z</StreamGeometry>
        <StreamGeometry x:Key="IconContentCopy">M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z</StreamGeometry>
        <StreamGeometry x:Key="IconContentSave">M17 3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V7L17 3M19 19H5V5H16.17L19 7.83V19M12 12C10.34 12 9 13.34 9 15S10.34 18 12 18 15 16.66 15 15 13.66 12 12 12M6 6H15V10H6V6Z</StreamGeometry>
        <StreamGeometry x:Key="IconCodeBraces">M8,3A2,2 0 0,0 6,5V9A2,2 0 0,1 4,11H3V13H4A2,2 0 0,1 6,15V19A2,2 0 0,0 8,21H10V19H8V14A2,2 0 0,0 6,12A2,2 0 0,0 8,10V5H10V3M16,3A2,2 0 0,1 18,5V9A2,2 0 0,0 20,11H21V13H20A2,2 0 0,0 18,15V19A2,2 0 0,1 16,21H14V19H16V14A2,2 0 0,1 18,12A2,2 0 0,1 16,10V5H14V3H16Z</StreamGeometry>
        <StreamGeometry x:Key="IconTextBox">M5,3C3.89,3 3,3.89 3,5V19C3,20.11 3.89,21 5,21H19C20.11,21 21,20.11 21,19V5C21,3.89 20.11,3 19,3H5M5,5H19V19H5V5M7,7V9H17V7H7M7,11V13H17V11H7M7,15V17H14V15H7Z</StreamGeometry>
        <StreamGeometry x:Key="IconSitemap">M9,2V8H11V11H5C3.89,11 3,11.89 3,13V16H1V22H7V16H5V13H11V16H9V22H15V16H13V13H19V16H17V22H23V16H21V13C21,11.89 20.11,11 19,11H13V8H15V2H9Z</StreamGeometry>
        <StreamGeometry x:Key="IconMagnify">M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</StreamGeometry>
        <StreamGeometry x:Key="IconPlusCircle">M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,7H11V11H7V13H11V17H13V13H17V11H13V7Z</StreamGeometry>
        <StreamGeometry x:Key="IconCog">M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.21,15.05 2.27,14.78 2.46,14.63L4.57,12.97L4.5,12L4.57,11L2.46,9.37C2.27,9.22 2.21,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.79,8.95 21.73,9.22 21.54,9.37L19.43,11L19.5,12L19.43,13L21.54,14.63C21.73,14.78 21.79,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10M11.25,4L10.88,6.61C9.68,6.86 8.62,7.5 7.85,8.39L5.44,7.35L4.69,8.65L6.8,10.2C6.4,11.37 6.4,12.64 6.8,13.8L4.68,15.36L5.43,16.66L7.86,15.62C8.63,16.5 9.68,17.14 10.87,17.38L11.24,20H12.76L13.13,17.39C14.32,17.14 15.37,16.5 16.14,15.62L18.57,16.66L19.32,15.36L17.2,13.81C17.6,12.64 17.6,11.37 17.2,10.2L19.31,8.65L18.56,7.35L16.15,8.39C15.38,7.5 14.32,6.86 13.12,6.62L12.75,4H11.25Z</StreamGeometry>
        <StreamGeometry x:Key="IconMessage">M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2M20 16H5.2L4 17.2V4H20V16Z</StreamGeometry>
        <StreamGeometry x:Key="IconShieldCheck">M21,11C21,16.55 17.16,21.74 12,23C6.84,21.74 3,16.55 3,11V5L12,1L21,5V11M12,21C15.75,20 19,15.54 19,11.22V6.3L12,3.18L5,6.3V11.22C5,15.54 8.25,20 12,21M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9</StreamGeometry>
        <StreamGeometry x:Key="IconHelpCircle">M15.07,11.25L14.17,12.17C13.45,12.89 13,13.5 13,15H11V14.5C11,13.39 11.45,12.39 12.17,11.67L13.41,10.41C13.78,10.05 14,9.55 14,9C14,7.89 13.1,7 12,7A2,2 0 0,0 10,9H8A4,4 0 0,1 12,5A4,4 0 0,1 16,9C16,9.88 15.64,10.67 15.07,11.25M13,19H11V17H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12C22,6.47 17.5,2 12,2Z</StreamGeometry>

        <!-- ══ SegmentedControl Item ═══════════════════════════════════════════════ -->
        <ControlTheme x:Key="SegmentedControlItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:selected /template/ Border#root">
                <Setter Property="Background" Value="{StaticResource BlueBrush}"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Foreground" Value="{StaticResource BaseBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style Selector="^:pointerover /template/ Border#root">
                <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            </Style>
            <Style Selector="^:selected:pointerover /template/ Border#root">
                <Setter Property="Background" Value="#a8c7ff"/>
            </Style>
        </ControlTheme>

        <!-- ══ SegmentedControl (ListBox wrapper) ══════════════════════════════════ -->
        <ControlTheme x:Key="SegmentedControl" TargetType="ListBox">
            <Setter Property="ItemContainerTheme" Value="{StaticResource SegmentedControlItem}"/>
            <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="Cursor" Value="Hand"/>
        </ControlTheme>

        <!-- ══ IconButton ══════════════════════════════════════════════════════════ -->
        <ControlTheme x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            </Style>
        </ControlTheme>

        <!-- ══ PrimaryButton ═══════════════════════════════════════════════════════ -->
        <ControlTheme x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BlueBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource BaseBrush}"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#a8c7ff"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
            </Style>
        </ControlTheme>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ══ SectionLabel ════════════════════════════════════════════════════════ -->
        <Style Selector="TextBlock.SectionLabel">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Overlay0Brush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- ══ RecentItem button ═══════════════════════════════════════════════════ -->
        <Style Selector="Button.RecentItem">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.RecentItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Surface0Brush}"/>
        </Style>
    </Application.Styles>
</Application>
