<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>DevContext.Desktop</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Ensures CLI + all dependencies are in the output folder for child process launch -->
    <ProjectReference Include="..\DevContext.Cli\DevContext.Cli.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Photino.NET" Version="3.1.*" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="wwwroot\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
