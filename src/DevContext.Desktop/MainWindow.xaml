<Window x:Class="DevContext.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:desktop="clr-namespace:DevContext.Desktop"
        Title="DevContext" Width="1200" Height="760"
        MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">
    <Grid>
        <wpf:BlazorWebView HostPage="wwwroot/index.html"
                            Services="{DynamicResource services}">
            <wpf:BlazorWebView.RootComponents>
                <wpf:RootComponent Selector="#app"
                                   ComponentType="{x:Type desktop:App}" />
            </wpf:BlazorWebView.RootComponents>
        </wpf:BlazorWebView>
    </Grid>
</Window>
