@inject MainViewModel VM
@inject IJSRuntime JS
@using DevContext.Desktop.ViewModels

@implements IDisposable

@code {
    private bool IsSectionsOpen;
    private bool _showWelcome;
    private string? _toastMessage;
    private System.Threading.CancellationTokenSource? _toastCts;

    protected override void OnInitialized()
    {
        VM.PropertyChanged += OnVmChanged;
    }
    public void Dispose()
    {
        VM.PropertyChanged -= OnVmChanged;
        _toastCts?.Dispose();
    }

    private void OnVmChanged(object? _, System.ComponentModel.PropertyChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private void SelectTab(string tab)
    {
        VM.Output.SelectedTab = tab switch
        {
            "human" => OutputViewModel.OutputTab.Human,
            "llm" => OutputViewModel.OutputTab.Llm,
            "stats" => OutputViewModel.OutputTab.Stats,
            _ => OutputViewModel.OutputTab.Human
        };
    }
    private void ToggleSections() => IsSectionsOpen = !IsSectionsOpen;
    private void ToggleGroup(SectionGroupViewModel group, bool value) { foreach (var c in group.Children) c.IsIncluded = value; }

    private async Task Copy() { try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", VM.HumanViewText); ShowToast("Copied!"); } catch { } }
    private async Task CopyLlm() { try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", VM.LlmViewText); ShowToast("Copied LLM view!"); } catch { } }
    private async Task Save()
    {
        try
        {
            var ext = VM.SelectedFormat == "json" ? "json" : "md";
            await JS.InvokeVoidAsync("saveFile", $"devcontext-output.{ext}", VM.RawContent);
            ShowToast("Saved!");
        }
        catch { }
    }

    private async void ShowToast(string message)
    {
        _toastCts?.Cancel();
        _toastCts?.Dispose();
        _toastCts = new System.Threading.CancellationTokenSource();
        _toastMessage = message;
        StateHasChanged();
        try { await Task.Delay(2000, _toastCts.Token); }
        catch (OperationCanceledException) { return; }
        _toastMessage = null;
        StateHasChanged();
    }

    private double BudgetPct => VM.BudgetTokens > 0 ? (double)VM.SelectedTokenTotal / VM.BudgetTokens * 100 : 0;
    private string BudgetState => VM.SelectedTokenTotal > VM.BudgetTokens ? "danger"
        : VM.SelectedTokenTotal >= VM.BudgetTokens * 0.85 ? "warning" : "normal";

    private bool IsTabHuman => VM.Output.SelectedTab == OutputViewModel.OutputTab.Human;
    private bool IsTabLlm => VM.Output.SelectedTab == OutputViewModel.OutputTab.Llm;
    private bool IsTabStats => VM.Output.SelectedTab == OutputViewModel.OutputTab.Stats;
}

<section class="output-panel">
    @if ((!VM.HasOutput && !VM.IsAnalyzing) || _showWelcome)
    {
        <div class="empty-state">
            @if (_showWelcome)
            {
                <button class="btn-icon empty-close" style="position:absolute;top:8px;right:8px" title="Close" @onclick="() => _showWelcome = false">
                    <svg class="icon" viewBox="0 0 24 24" style="width:18px;height:18px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            }
            <div class="empty-hero">
                <svg class="icon" viewBox="0 0 24 24" style="width:56px;height:56px;opacity:0.25"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                <h2 class="empty-title">Structured context for LLMs</h2>
                <p class="empty-desc">DevContext analyzes your .NET codebase and produces a pruned, token-budgeted document ready to paste into any LLM.</p>
            </div>
            <div class="empty-features">
                <div class="empty-feat"><span class="feat-icon">&check;</span> Discover endpoints, workers, entities, DI wiring, middleware</div>
                <div class="empty-feat"><span class="feat-icon">&check;</span> Prune to fit your token budget (500&ndash;50,000)</div>
                <div class="empty-feat"><span class="feat-icon">&check;</span> Natural language intent &mdash; type what you need</div>
                <div class="empty-feat"><span class="feat-icon">&check;</span> GitHub URL support &mdash; clone &amp; analyze in one click</div>
                <div class="empty-feat"><span class="feat-icon">&check;</span> Human view (rendered) and LLM view (raw) tabs</div>
            </div>
            <p class="empty-hint">Enter a project path or GitHub URL in the sidebar, then click Analyze.</p>
        </div>
    }
    else
    {
        <div class="output-toolbar">
            <div class="tabs">
                <button class="@(IsTabHuman?"tab active":"tab")" @onclick='()=>SelectTab("human")'>Human</button>
                <button class="@(IsTabLlm?"tab active":"tab")" @onclick='()=>SelectTab("llm")'>LLM</button>
                <button class="@(IsTabStats?"tab active":"tab")" @onclick='()=>SelectTab("stats")'>Stats</button>
                @if (VM.SectionGroups.Length > 1 && !VM.HasGraph)
                {
                    <button class="btn-sections" @onclick="ToggleSections">
                        <svg class="icon" viewBox="0 0 24 24"><rect x="15" y="3" width="6" height="18" rx="2"/><path d="M9 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h4"/></svg> Sections
                        @if (VM.SectionGroups.SelectMany(g=>g.Children).Count(s=>!s.IsIncluded) > 0)
                        {
                            <span class="badge">@VM.SectionGroups.SelectMany(g=>g.Children).Count(s=>!s.IsIncluded)</span>
                        }
                    </button>
                }
            </div>
            <div class="toolbar-actions">
                <button class="btn-icon" title="What is this?" @onclick="() => _showWelcome = !_showWelcome">?</button>
                <button class="btn-icon" title="Copy to clipboard" @onclick="Copy"><svg class="icon" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
                <button class="btn-icon" title="Save to file" @onclick="Save"><svg class="icon" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
                <button class="btn-icon" title="Copy for LLM" @onclick="CopyLlm"><svg class="icon" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/><polyline points="14 15 17 18 22 13"/></svg></button>
            </div>
        </div>

        @if (IsSectionsOpen && VM.SectionGroups.Length > 1)
        {
            <div class="sections-drawer">
                <div class="section-budget">
                    <div class="budget-bar-wrapper">
                        <div class="budget-bar"><div class="budget-fill @BudgetState" style="width:@(Math.Min(100,BudgetPct))%"></div></div>
                        <span class="budget-text @(VM.SelectedTokenTotal>VM.BudgetTokens?"danger":"")">@VM.SelectedTokenTotal.ToString("N0") / @VM.BudgetTokens.ToString("N0") tokens</span>
                    </div>
                    <button class="btn-text" @onclick="()=>VM.ResetToScenarioDefaultsCommand.Execute(null)">Reset to defaults</button>
                </div>
                @foreach (var group in VM.SectionGroups)
                {
                    <details open>
                        <summary>
                            <label><input type="checkbox" checked="@group.IsIncluded" @onchange="@(e=>ToggleGroup(group,(bool)(e.Value??false)))" /> @group.Name</label>
                            <span class="group-tokens">@group.TotalTokens.ToString("N0") tok</span>
                        </summary>
                        @foreach (var section in group.Children)
                        {
                            <label class="section-row" style="padding-left:20px">
                                <input type="checkbox" checked="@section.IsIncluded" @onchange="@(e=>section.IsIncluded=(bool)(e.Value??false))" />
                                @section.Name
                                <span class="section-tokens">@section.CompressedTokens.ToString("N0") tok</span>
                            </label>
                        }
                    </details>
                }
            </div>
        }

        @if (IsTabHuman)
        {
            <div class="output-rendered">@((MarkupString)VM.HumanViewHtml)</div>
        }
        else if (IsTabStats)
        {
            <div class="output-rendered">@((MarkupString)VM.StatsHtml)</div>
        }
        else
        {
            <pre class="output-text"><code>@VM.LlmViewText</code></pre>
        }

        @if (VM.IsAnalyzing)
        {
            <div class="loading-overlay"><div class="spinner"></div><p>@VM.ProgressText</p></div>
        }
    }
    @if (_toastMessage is not null)
    {
        <div class="toast">@_toastMessage</div>
    }
</section>
