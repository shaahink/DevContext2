@inject MainViewModel VM
@using DevContext.Cli
@using DevContext.Core.Graph

@implements IDisposable

@code {
    // Entry combobox: a searchable browse-and-pick over the graph's entry inventory. The query is
    // local — VM.Focus (which drives analysis) only changes when an entry is picked or Enter is
    // pressed, so browsing never re-analyzes.
    private string _entryQuery = "";
    private bool _entryOpen;

    protected override void OnInitialized()
    {
        VM.PropertyChanged += OnVmChanged;
        _entryQuery = VM.Focus;
    }

    private void OnVmChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        // Keep the box text in sync when Focus changes elsewhere (loaded settings, cleared, etc.).
        if (string.IsNullOrEmpty(e.PropertyName) || e.PropertyName == nameof(MainViewModel.Focus))
            _entryQuery = VM.Focus;
        InvokeAsync(StateHasChanged);
    }

    private void OnDepthInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            VM.Depth = Math.Clamp(v, 1, 10);
    }

    private void OnEntryInput(ChangeEventArgs e)
    {
        _entryQuery = e.Value?.ToString() ?? "";
        _entryOpen = true;
    }

    private void OnEntryKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") CommitFocus(_entryQuery);
        else if (e.Key == "Escape") _entryOpen = false;
    }

    private void ToggleEntryList() => _entryOpen = !_entryOpen;

    private void SelectEntry(EntryPoint entry)
    {
        _entryQuery = entry.Title;
        CommitFocus(entry.Title);
    }

    private void ClearFocus() => CommitFocus("");

    private void CommitFocus(string value)
    {
        _entryOpen = false;
        _entryQuery = value;
        if (VM.Focus != value) VM.Focus = value; // triggers debounced re-analysis
    }

    private List<KeyValuePair<string, List<EntryPoint>>> FilteredGroups()
    {
        var q = _entryQuery?.Trim() ?? "";
        bool Match(EntryPoint e) =>
            q.Length == 0
            || e.Title.Contains(q, StringComparison.OrdinalIgnoreCase)
            || (e.Target?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false);

        var result = new List<KeyValuePair<string, List<EntryPoint>>>();
        foreach (var g in VM.GroupedEntries)
        {
            var items = g.Where(Match).ToList();
            if (items.Count > 0) result.Add(new(g.Key, items));
        }
        return result;
    }

    public void Dispose() => VM.PropertyChanged -= OnVmChanged;
}

<aside class="config-panel">
    <header class="config-header">
        <h1 class="app-title">
            <svg class="icon" viewBox="0 0 24 24"><path d="M8 3a2 2 0 0 0-2 2v4a2 2 0 0 1-2 2H3v2h1a2 2 0 0 1 2 2v4a2 2 0 0 0 2 2h2v-2H8v-5a2 2 0 0 0-2-2 2 2 0 0 0 2-2V5h2V3m6 0a2 2 0 0 1 2 2v4a2 2 0 0 0 2 2h1v2h-1a2 2 0 0 0-2 2v4a2 2 0 0 1-2 2h-2v-2h2v-5a2 2 0 1 1 2-2 2 2 0 0 1-2-2V5h-2V3h2z"/></svg>
            DevContext <span class="version">v@DevContext.Cli.DevContextVersion.Display</span>
        </h1>
    </header>

    <nav class="config-sections">

        @* ── Source ─────────────────────────────────────────────── *@
        <section class="config-group">
            <h2 class="group-label">Source</h2>
            <div class="source-row">
                <input class="input" placeholder="Path, .sln, .csproj, or github.com/user/repo"
                       @bind="VM.ProjectPath" @bind:event="oninput" />
            </div>

            @if (VM.IsGitHubUrl)
            {
                <div class="github-pill">
                    <span class="pill-text">@VM.GitRepoDisplay</span>
                    <select class="cleanup-select" @bind="VM.CloneCleanup">
                        <option value="auto">Auto-clean on exit</option>
                        <option value="keep">Keep permanently</option>
                    </select>
                </div>
            }

            @if (VM.RecentPaths.Count > 0)
            {
                <div class="recent-list">
                    @foreach (var path in VM.RecentPaths)
                    {
                        <button class="chip" title="@path"
                                @onclick="() => VM.SelectRecentCommand.Execute(path)">
                            @(path.Contains('/') ? path.Split('/').Last() : System.IO.Path.GetFileName(path.TrimEnd('\\')))
                        </button>
                    }
                </div>
            }
        </section>

        @* ── Focus / entry point (single searchable control; mode is derived) ── *@
        <section class="config-group entry-combo">
            <h2 class="group-label">
                Focus <span class="hint">(optional)</span>
                <span class="mode-badge @(VM.IsTraceMode ? "trace" : "map")">@(VM.IsTraceMode ? "Trace" : "Map")</span>
            </h2>
            <div class="entry-input-row">
                <input class="input entry-input" placeholder="Type a symbol, or pick an entry…"
                       value="@_entryQuery"
                       @oninput="OnEntryInput"
                       @onfocus="() => _entryOpen = VM.HasGraph"
                       @onkeydown="OnEntryKeyDown" />
                @if (VM.HasGraph && VM.Entries.Count > 0)
                {
                    <button class="entry-btn" type="button" title="Browse entry points" @onclick="ToggleEntryList">▾</button>
                }
                @if (!string.IsNullOrEmpty(VM.Focus))
                {
                    <button class="entry-btn entry-clear" type="button" title="Clear — back to Map" @onclick="ClearFocus">✕</button>
                }
            </div>

            @if (_entryOpen && VM.HasGraph && VM.Entries.Count > 0)
            {
                <div class="entry-backdrop" @onclick="() => _entryOpen = false"></div>
                <div class="entry-dropdown">
                    @{ var groups = FilteredGroups(); }
                    @if (groups.Count == 0)
                    {
                        <div class="entry-none">No match. Press Enter to use “@_entryQuery” as a focus.</div>
                    }
                    @foreach (var grp in groups)
                    {
                        <div class="entry-group">@grp.Key <span class="entry-group-count">@grp.Value.Count</span></div>
                        @foreach (var e in grp.Value)
                        {
                            <button class="entry-option" type="button" @onclick="() => SelectEntry(e)">
                                <span class="entry-option-title">@e.Title</span>
                                @if (!string.IsNullOrEmpty(e.Target))
                                {
                                    <span class="entry-option-target">→ @e.Target</span>
                                }
                            </button>
                        }
                    }
                </div>
            }
            <p class="field-hint">
                @if (VM.IsTraceMode)
                {
                    <span>Tracing <strong>@VM.Focus</strong>. Pick another entry, or clear for the whole-codebase Map.</span>
                }
                else if (VM.HasGraph)
                {
                    <span>Empty → whole-codebase Map. Pick an entry to trace it (or type a symbol + Enter).</span>
                }
                else
                {
                    <span>Empty → whole-codebase Map. After analysis, pick an entry here to trace.</span>
                }
            </p>
        </section>

        @* ── Depth & Detail (Trace only — focus set) ── *@
        @if (VM.IsTraceMode)
        {
            <section class="config-group">
                <h2 class="group-label">Depth</h2>
                <div class="token-slider">
                    <input type="range" min="1" max="10" step="1"
                           value="@VM.Depth" @onchange="OnDepthInput" />
                    <input type="number" class="input token-input" min="1" max="10"
                           value="@VM.Depth" @onchange="OnDepthInput" />
                </div>
                <p class="field-hint">Hops to follow from the entry (default 6).</p>
            </section>

            <section class="config-group">
                <h2 class="group-label">Detail</h2>
                <div class="segmented">
                    @foreach (var d in new[] { ("signature", "Signature"), ("salient", "Salient"), ("full", "Full") })
                    {
                        <button class="seg-option @(VM.Detail == d.Item1 ? "active" : "")"
                                @onclick="() => VM.Detail = d.Item1" type="button">
                            @d.Item2
                        </button>
                    }
                </div>
                <p class="field-hint">Signature = names only, Salient = key body lines, Full = method slice.</p>
            </section>
        }

        @* ── Output ────────────────────────────────────────────────── *@
        <section class="config-group">
            <h2 class="group-label">Output</h2>

            <label class="field-label">Format</label>
            <div class="segmented">
                @foreach (var f in new[] { ("markdown", "Markdown"), ("json", "JSON") })
                {
                    <button class="seg-option @(VM.SelectedFormat == f.Item1 ? "active" : "")"
                            @onclick="() => VM.SetFormatCommand.Execute(f.Item1)">
                        @f.Item2
                    </button>
                }
            </div>

            <details class="advanced">
                <summary class="advanced-summary">Advanced</summary>
                <div class="advanced-body">
                    <label class="toggle-label">
                        <input type="checkbox" checked="@VM.IncludeDiagnostics"
                               @onchange="@(e => VM.IncludeDiagnostics = (bool)(e.Value ?? false))" />
                        Include diagnostics
                    </label>
                    <label class="toggle-label">
                        <input type="checkbox" checked="@VM.NoRoslyn"
                               @onchange="@(e => VM.NoRoslyn = (bool)(e.Value ?? false))" />
                        Skip Roslyn (faster, no semantic analysis)
                    </label>
                    <label class="toggle-label">
                        <input type="checkbox" checked="@VM.DryRun"
                               @onchange="@(e => VM.DryRun = (bool)(e.Value ?? false))" />
                        Dry run (plan only)
                    </label>
                    @* Provenance + anti-patterns only affect the legacy catalog output (no graph). *@
                    @if (!VM.HasGraph)
                    {
                        <label class="toggle-label">
                            <input type="checkbox" checked="@VM.IncludeProvenance"
                                   @onchange="@(e => VM.IncludeProvenance = (bool)(e.Value ?? false))" />
                            Include provenance
                        </label>
                        <label class="toggle-label">
                            <input type="checkbox" checked="@VM.IncludeAntiPatterns"
                                   @onchange="@(e => VM.IncludeAntiPatterns = (bool)(e.Value ?? false))" />
                            Include anti-pattern detection
                        </label>
                    }
                </div>
            </details>
        </section>

    </nav>

    <footer class="config-footer">
        <button class="btn-primary" @onclick="() => VM.AnalyzeCommand.Execute(null)"
                disabled="@(string.IsNullOrWhiteSpace(VM.ProjectPath))">
            @VM.AnalyzeButtonText
        </button>
    </footer>
</aside>
